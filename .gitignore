## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This is a combination of standard patterns from the
## GitHub .gitignore repository and custom rules.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio Code
.vscode/

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Log
*.svclog
*.trc

# CoreTools
gpg.err

# Backup & checkpoint files from MS Build
node_modules/
bower_components/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework 6+ (this is relevant since we use EF Core)
*.Migrated.xml

# Microsoft Azure
# azure-pipelines/*.yml

# Microsoft SQL Server settings
*.sqlproj.user

# Mac OS metadata
.DS_Store

# User-specific files for some editors
.idea/
.project
.settings/
.classpath

# Rider
.idea/
*.sln.iml

# User-specific files (Docker)
.dockerignore
docker-compose.override.yml

# Personal settings
appsettings.json
# !appsettings.json
appsettings.Development.json
!appsettings.Development.json
